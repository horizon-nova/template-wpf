# 排除 Visual Studio 和 VS Code 的暫存檔案與設定
.vs/
.vscode/

# 排除編譯輸出的二進位檔案
bin/
obj/

# 排除本地配置檔案
*.suo
*.user
*.userosscache
*.sln.docstates

# 排除進階設定檔案
*.csproj.nuget.dgspec.json
*.csproj.nuget.g.props
*.csproj.nuget.g.targets

# 排除其他暫存檔案
*.tmp
*.log
*.vsidx
*.cache
*.exe
*.dll
*.pdb
*.db
*.lock

# NuGet 相關 (允許 `packages/`，但忽略還原時的 cache 和 log)
# 排除 NuGet 還原的中繼文件
.nuget/
packages/**/*.nupkg
packages/**/*.snupkg
packages/**/*.sha512
packages/**/project.assets.json
packages/**/project.nuget.cache
packages/**/project.lock.json
packages/**/restore.lock.json

# 允許 NuGet 套件
!packages/
!packages/**/*.dll
!packages/**/*.exe
!packages/**/*.pdb

# 排除所有 ONNX 模型
*.onnx

# 排除 tokenizer 相關檔案
tokenizer.json
tokenizer_config.json
vocab.json
merges.txt
special_tokens_map.json

# 排除資料夾
HNB/Areas/Backoffice/storage/

Sites/

QdrantEmbedding

# Node.js
npm-debug.log
yarn-debug.log
yarn-error.log
